# ===== Claude API =====
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx
CLAUDE_SCRIPT_MODEL=claude-sonnet-4-6
CLAUDE_FILTER_MODEL=claude-haiku-4-5-20251001

# ===== Cloudflare R2 =====
R2_ACCESS_KEY=xxxxxxxx
R2_SECRET_KEY=xxxxxxxx
R2_BUCKET=podcast-episodes
R2_ENDPOINT=https://xxxxxxxx.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://pub-xxxxxxxx.r2.dev

# ===== Podcast 元資料 =====
PODCAST_TITLE=00981A 每日持股觀察
PODCAST_AUTHOR=AI 主播
PODCAST_EMAIL=your-email@example.com
PODCAST_DESCRIPTION=每個交易日追蹤統一台股增長主動式 ETF (00981A) 的持股變化，剖析背後的投資策略與個股催化劑。
PODCAST_LANGUAGE=zh-TW
PODCAST_CATEGORY=Business
PODCAST_SUBCATEGORY=Investing
PODCAST_EXPLICIT=false
PODCAST_HOMEPAGE=https://USERNAME.github.io/REPO_NAME
PODCAST_COVER_URL=https://USERNAME.github.io/REPO_NAME/cover.png

# ===== TTS 設定 =====
TTS_VOICE=zh-TW-HsiaoChenNeural
TTS_RATE=+0%
TTS_PITCH=+0Hz

# ===== 通知（選用） =====
DISCORD_WEBHOOK=

# ===== 開發旗標 =====
DRY_RUN=false
